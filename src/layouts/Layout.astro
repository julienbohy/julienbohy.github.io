---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, path, image, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="fr" data-theme="winter">
  <head>
    <BaseHead title={title} description={description} path={path} image={image} jsonLd={jsonLd} />
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved || (systemDark ? 'dark' : 'winter');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <Header />
    <main class="py-8 md:py-12">
      <div class="container-shell">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
