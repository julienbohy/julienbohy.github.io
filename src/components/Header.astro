---
import { deriveSiteNameFromUrl, siteConfig } from '../config/site';

const siteName = deriveSiteNameFromUrl(siteConfig.siteUrl);
const links = [
  { href: '/', label: 'Accueil' },
  { href: '/blog', label: 'Articles' },
  { href: '/portfolio', label: 'Projets' },
  { href: '/cv', label: 'CV' },
  { href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname;
---
<header class="sticky top-0 z-30 border-b border-base-300/70 bg-base-100/90 backdrop-blur">
  <div class="container-shell">
    <nav class="flex items-center justify-between gap-4 py-3">
      <a href="/" class="text-xl font-bold tracking-tight">{siteName}</a>
      <div class="flex flex-wrap items-center gap-2">
        {links.map((link) => (
          <a
            href={link.href}
            aria-current={pathname === link.href || pathname.startsWith(`${link.href}/`) ? 'page' : undefined}
            class="btn btn-ghost btn-sm aria-[current=page]:btn-active"
          >
            {link.label}
          </a>
        ))}
        <label class="swap swap-rotate btn btn-ghost btn-sm" aria-label="Changer le thème">
          <input id="theme-toggle" type="checkbox" />
          <svg class="swap-off h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M5.64,17l-.71.71L3.5,16.29l.71-.71ZM12,4V1h-1V4Zm7.5,12.29-.71.71L17.29,17l.71-.71ZM20,13h3V12H20ZM4,12H1v1H4ZM12,20v3h1V20ZM6.34,6.34,4.93,4.93,3.5,6.36,4.91,7.77ZM19.07,4.93,17.66,6.34l1.41,1.43,1.41-1.41ZM12.5,7a5.5,5.5,0,1,0,5.5,5.5A5.5,5.5,0,0,0,12.5,7Z" />
          </svg>
          <svg class="swap-on h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M21.64,13a1,1,0,0,0-1.05-.14A8.05,8.05,0,0,1,17.22,13A8.15,8.15,0,0,1,9.08,4.78a8.59,8.59,0,0,1,.25-2,1,1,0,0,0-1.45-1.11A10.14,10.14,0,1,0,22.33,16.11,1,1,0,0,0,21.64,13Z" />
          </svg>
        </label>
      </div>
    </nav>
  </div>
</header>
<script is:inline>
  (() => {
    const root = document.documentElement;
    const input = document.getElementById('theme-toggle');
    if (!input) return;

    const current = root.getAttribute('data-theme') || 'winter';
    input.checked = current === 'dark';

    input.addEventListener('change', () => {
      const next = input.checked ? 'dark' : 'winter';
      root.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });
  })();
</script>
