---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { buildBreadcrumbSchema } from '../../lib/seo';
import { siteConfig } from '../../config/site';
import MediaPlaceholder from '../../components/MediaPlaceholder.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const rootUrl = Astro.site ?? new URL(siteConfig.siteUrl);

const breadcrumbs = buildBreadcrumbSchema([
  { name: 'Accueil', item: new URL('/', rootUrl).toString() },
  { name: 'Portfolio', item: new URL('/portfolio', rootUrl).toString() },
  { name: project.data.title, item: new URL(`/portfolio/${project.slug}`, rootUrl).toString() },
]);
---
<Layout title={project.data.title} description={project.data.summary} path={`/portfolio/${project.slug}`} jsonLd={breadcrumbs}>
  <article class="rounded-xl border border-base-300 bg-base-200 p-6 shadow-sm">
    <MediaPlaceholder
      title="Hero du projet"
      hint="Capture principale de l'interface finale (écran complet) pour montrer la qualité visuelle."
      ratio="wide"
    />
    <p class="mt-4 text-xs uppercase tracking-wide text-base-content/70">{new Date(project.data.date).toLocaleDateString('fr-FR')}</p>
    <h1 class="mt-2 text-4xl">{project.data.title}</h1>
    <p class="mt-3 text-base-content/70">{project.data.summary}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {project.data.tech.map((tech) => <span class="rounded-full bg-secondary px-2.5 py-0.5 text-xs font-medium text-secondary-content">{tech}</span>)}
    </div>
    <div class="mt-5 flex flex-wrap gap-3">
      {project.data.demoUrl && <a class="inline-flex h-10 items-center rounded-md bg-foreground px-4 text-sm font-medium text-background hover:bg-foreground/90" href={project.data.demoUrl}>Démo</a>}
      {project.data.repoUrl && <a class="inline-flex h-10 items-center rounded-md border border-base-300 bg-base-100 px-4 text-sm font-medium hover:bg-base-200" href={project.data.repoUrl}>Code source</a>}
    </div>
    <div class="prose-content mt-6">
      <Content />
    </div>
  </article>
</Layout>
