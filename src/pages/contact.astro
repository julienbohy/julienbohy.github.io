---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';
import MediaPlaceholder from '../components/MediaPlaceholder.astro';
---
<Layout title="Contact" description="Me contacter" path="/contact">
  <section class="rounded-xl border border-base-300 bg-base-200 p-6 shadow-sm">
    <h1 class="text-4xl">Contact</h1>
    <p class="mt-3 text-base-content/70">Pour une collaboration, contactez-moi directement via LinkedIn.</p>
    <a
      class="mt-6 inline-flex h-10 items-center rounded-md bg-foreground px-4 text-sm font-medium text-background hover:bg-foreground/90"
      href={siteConfig.primaryContact.href}
      target="_blank"
      rel="noreferrer"
    >
      Contacte-moi sur LinkedIn
    </a>

    <div class="mt-6 flex flex-wrap gap-2">
      {siteConfig.socials.map((social) => (
        <a class="rounded-full border border-base-300 bg-base-100 px-3 py-1 text-xs font-medium hover:bg-base-200" href={social.href} target="_blank" rel="noreferrer">{social.label}</a>
      ))}
    </div>
    <div class="mt-6">
      <MediaPlaceholder
        title="Visuel de disponibilité"
        hint="Optionnel: image de couverture (workspace ou branding) pour humaniser la page contact."
        ratio="wide"
      />
    </div>
  </section>
</Layout>
