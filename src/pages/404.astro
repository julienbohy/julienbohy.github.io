---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404" description="Page introuvable" path="/404">
  <section class="rounded-xl border border-base-300 bg-base-200 p-6 shadow-sm">
    <h1 class="text-4xl">Page introuvable</h1>
    <p class="mt-3 text-base-content/70">Le contenu demandé n'existe pas ou a été déplacé.</p>
    <a class="mt-5 inline-flex h-10 items-center rounded-md bg-foreground px-4 text-sm font-medium text-background hover:bg-foreground/90" href="/">Retour à l'accueil</a>
  </section>
</Layout>
