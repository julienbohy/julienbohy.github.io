---
import Layout from '../../../../layouts/Layout.astro';
import PostCard from '../../../../components/PostCard.astro';
import { siteConfig } from '../../../../config/site';
import { getPublishedPosts, matchSeries } from '../../../../lib/content';
import { paginate, slugify } from '../../../../lib/content-utils.js';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const series = Array.from(new Set(posts.map((post) => (post.data.series ? slugify(post.data.series) : undefined)).filter(Boolean)));
  return series.map((item) => ({ params: { series: item } }));
}

const series = String(Astro.params.series);
const posts = (await getPublishedPosts()).filter((post) => matchSeries(post, series));
const page = paginate(posts, 1, siteConfig.blogPageSize);
const basePath = `/blog/series/${series}`;
---
<Layout title={`Série: ${series}`} description={`Articles de la série ${series}`} path={basePath}>
  <section>
    <h1 class="text-4xl">Série: {series}</h1>
  </section>
  <section class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {page.items.map((post) => <PostCard post={post} />)}
  </section>
  <nav class="mt-6 flex items-center gap-3">
    <span class="text-sm text-base-content/70">Page {page.currentPage} / {page.totalPages}</span>
    {page.currentPage < page.totalPages && <a class="inline-flex h-9 items-center rounded-md border border-base-300 bg-base-200 px-3 text-sm hover:bg-base-100" href={`${basePath}/${page.currentPage + 1}`}>Suivant</a>}
  </nav>
</Layout>
