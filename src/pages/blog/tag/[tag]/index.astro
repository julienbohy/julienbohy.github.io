---
import Layout from '../../../../layouts/Layout.astro';
import PostCard from '../../../../components/PostCard.astro';
import { siteConfig } from '../../../../config/site';
import { getPublishedPosts, matchTag } from '../../../../lib/content';
import { paginate, slugify } from '../../../../lib/content-utils.js';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags.map((tag) => slugify(tag)))));
  return tags.map((tag) => ({ params: { tag } }));
}

const tag = String(Astro.params.tag);
const posts = (await getPublishedPosts()).filter((post) => matchTag(post, tag));
const page = paginate(posts, 1, siteConfig.blogPageSize);
const basePath = `/blog/tag/${tag}`;
---
<Layout title={`Tag: ${tag}`} description={`Articles taggés ${tag}`} path={basePath}>
  <section>
    <h1 class="text-4xl">Tag: {tag}</h1>
  </section>
  <section class="mt-4 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {page.items.map((post) => <PostCard post={post} />)}
  </section>
  <nav class="mt-6 flex items-center gap-3">
    <span class="text-sm text-base-content/70">Page {page.currentPage} / {page.totalPages}</span>
    {page.currentPage < page.totalPages && <a class="inline-flex h-9 items-center rounded-md border border-base-300 bg-base-200 px-3 text-sm hover:bg-base-100" href={`${basePath}/${page.currentPage + 1}`}>Suivant</a>}
  </nav>
</Layout>
