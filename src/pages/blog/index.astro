---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import SearchBox from '../../components/SearchBox.astro';
import { siteConfig } from '../../config/site';
import { getPublishedPosts } from '../../lib/content';
import { paginate } from '../../lib/content-utils.js';

const posts = await getPublishedPosts();
const page = paginate(posts, 1, siteConfig.blogPageSize);
---
<Layout title="Blog" description="Articles techniques" path="/blog">
  <section>
    <h1 class="text-4xl">Blog</h1>
    <p class="mt-2 text-base-content/70">Articles sur Astro, performance, contenu et SEO.</p>
  </section>

  <SearchBox />

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {page.items.map((post) => <PostCard post={post} />)}
  </section>

  <Pagination currentPage={1} totalPages={page.totalPages} basePath="/blog" />
</Layout>
